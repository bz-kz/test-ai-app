# --- Python ---
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual Environments
venv/
.venv/
env/
.env/
ENV/

# uv 依存解決ロック (プロジェクトは requirements.txt を信頼; uv はローカルツール扱い)
uv.lock

# Django/Flask specific
db.sqlite3
.env
.secrets
.pytest_cache/
.coverage
htmlcov/

# --- React (Node) ---
node_modules/
.pnp
.pnp.js
coverage/
build/
dist/

# IDE/Editor (VS Code)
.vscode/
.idea/

# OS specific
.DS_Store
Thumbs.db

# フロントエンドの src/lib/ はルートの lib/ パターンに誤マッチするため除外を解除
!frontend/src/lib/
!frontend/src/lib/**

# Playwright MCP の一時アーティファクト (snapshot YAML / console log / screenshot)。
# Option C の UI 検証で main loop が生成する; リポジトリに commit しない。
.playwright-mcp/
# リポジトリルートに出力される PNG / JPG (Playwright スクリーンショット等の調査用一時ファイル)。
# サブディレクトリの実際のアセットを誤って無視しないよう、明示的にリポジトリ直下のみ対象とする。
/*.png
/*.jpg
/*.jpeg

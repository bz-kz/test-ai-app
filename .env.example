DD_API_KEY=<Datadog API key>
DD_SITE=ap1.datadoghq.com   # AP1 (東京)
DD_APP_KEY=<DD_APP_KEY>
DD_API_KEY=<DD_API_KEY

# ADR-0006 FE-015: Datadog Browser RUM 設定
# Datadog UI → UX Monitoring → RUM Applications → New Application で作成。
# applicationId / clientToken は public-by-design (ブラウザに渡る) だが
# git には commit しない。
NEXT_PUBLIC_RUM_ENABLED=false                              # true で RUM 起動
NEXT_PUBLIC_DD_RUM_APPLICATION_ID=<RUM Application ID UUID>
NEXT_PUBLIC_DD_RUM_CLIENT_TOKEN=<RUM Client Token>
NEXT_PUBLIC_DD_SITE=ap1.datadoghq.com                      # DD_SITE と同値を推奨
NEXT_PUBLIC_DD_RUM_SERVICE=frontend-browser                # APM service:frontend と区別
NEXT_PUBLIC_DD_RUM_ENV=local
NEXT_PUBLIC_DD_RUM_VERSION=dev
